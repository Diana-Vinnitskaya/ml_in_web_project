PROJECT_NAME=RuFeedback Classifier
API_PREFIX=/api/v1
MODEL_NAME=local-tfidf-logreg
MODEL_VERSION=0.1.0
MAX_TEXT_LENGTH=2000
MAX_BATCH_SIZE=32
MODEL_PATH=/app/models/feedback_classifier.joblib
MODEL_METRICS_PATH=/app/models/metrics.json
TRAIN_DATA_PATH=/app/data/train.csv
DATABASE_URL=postgresql+psycopg://rufeedback:rufeedback@postgres:5432/rufeedback
POSTGRES_DB=rufeedback
POSTGRES_USER=rufeedback
POSTGRES_PASSWORD=rufeedback
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
UI_HOST=0.0.0.0
UI_PORT=8501
NGINX_PORT=80
PROMETHEUS_SCRAPE_INTERVAL=15s
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
LOG_LEVEL=INFO
